<strings>
    <string id="AppName">Analog Simple</string>
    <!-- Bumped on every .iq (store) build; keep in sync with the git tag -->
    <string id="AppVersion">1.1.1-beta2</string>

    <!-- Setting titles -->
    <string id="HandStyleTitle">Hand Style</string>
    <string id="HourHandColorTitle">Hour Hand Color</string>
    <string id="MinuteHandColorTitle">Minute Hand Color</string>
    <string id="ShowSecondHandTitle">Show Second Hand</string>
    <string id="SecondHandColorTitle">Second Hand Color</string>
    <string id="BackgroundColorTitle">Background Color</string>
    <string id="TickColorTitle">Tick Mark Color</string>
    <string id="DateColorTitle">Date Color</string>
    <string id="ShowRainForecastTitle">Rain Forecast</string>
    <string id="ShowRainForecastPrompt">Show the next 12 hours of rain amount as a blue band around the bezel that deepens with heavier rain (12 o'clock = soonest hour, clockwise). Uses Open-Meteo; needs location and a phone connection to refresh.</string>
    <string id="ShowCloudCoverTitle">Cloud Cover</string>
    <string id="ShowCloudCoverPrompt">Show cloud cover as three grey lines (low, mid, high altitude) — higher cloud sits closer to the centre, and each line thickens with that layer's coverage.</string>
    <string id="CloudCoverRippleTitle">Cloud Color Ripple</string>
    <string id="CloudCoverRipplePrompt">Vary each cloud line's colour in waves along the ring instead of a flat tint. Turn off if it causes Always-On Display to shut off due to the extra drawing work.</string>
    <string id="ShowWeatherInAODTitle">Weather in Always-On</string>
    <string id="ShowWeatherInAODPrompt">Keep showing the forecast while the screen is dimmed (always-on). To stay within the always-on power budget it draws a single lightweight cloud outline ring (thicker = cloudier) plus a thin rain outline, instead of the full bands. Leave off if always-on still switches off on your watch.</string>
    <string id="LocationOverrideTitle">Location Override</string>
    <string id="LocationOverridePrompt">Force the weather location as "latitude,longitude" (e.g. 51.5,-0.12). Leave blank to use the watch's GPS or synced weather location.</string>
    <string id="RingDataSourceTitle">Battery Ring Source</string>
    <string id="RingColorByLevelTitle">Color Ring By Level</string>
    <string id="ColorblindModeTitle">Colorblind Mode</string>
    <string id="ColorblindModePrompt">Use a red-green colorblind-friendly ring palette (red / amber / blue) instead of red / yellow / green.</string>
    <string id="RingColorTitle">Ring Color</string>

